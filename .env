# ============================================================================
# OLT SUPERVISION PLATFORM - ENVIRONMENT VARIABLES
# ============================================================================

# ============================================================================
# DJANGO CORE
# ============================================================================
DEBUG=True
SECRET_KEY=django-insecure-hob-u(oh$bfu9z8jb09a@x)sb4otmthv%9jsk49j+9ha#$*qa#
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=Europe/Paris
LANGUAGE_CODE=fr-fr

# ============================================================================
# DATABASES
# ============================================================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=olt_supervision_db
DB_USER=olt_supervision_admin
DB_PASSWORD=123456
DB_HOST=localhost
DB_PORT=5432

# ============================================================================
# REDIS / CELERY (pour collecte SNMP asynchrone et tâches planifiées)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TIMEZONE=Europe/Paris
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1200

# ============================================================================
# EMAIL CONFIGURATION (pour notifications d'alertes)
# ============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=yourpassword
DEFAULT_FROM_EMAIL=noreply@oltsupervision.com
DEFAULT_TO_EMAIL=admin@oltsupervision.com

# ============================================================================
# CORS & CSRF (pour communication avec frontend)
# ============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
INTERNAL_IPS=127.0.0.1,localhost

# ============================================================================
# SMS / SLACK / TEAMS (optionnel, pour notifications)
# ============================================================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_DEFAULT_CHANNEL=#alerts

TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ============================================================================
# JWT AUTHENTICATION (si utilisée)
# ============================================================================
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ============================================================================
# FRONTEND (si dashboard séparé)
# ============================================================================
FRONTEND_URL=http://localhost:3000
FRONTEND_DASHBOARD_URL=http://localhost:3000/dashboard
BACKEND_URL=http://localhost:8000

# ============================================================================
# FILE STORAGE
# ============================================================================
MEDIA_URL=/media/
MEDIA_ROOT=/home/user/olt_supervision/media
STATIC_URL=/static/
STATIC_ROOT=/home/user/olt_supervision/static

# ============================================================================
# SNMP COLLECTION (paramètres par défaut)
# ============================================================================
SNMP_DEFAULT_COMMUNITY=public
SNMP_DEFAULT_PORT=161
SNMP_TIMEOUT=5
SNMP_RETRIES=2

# ============================================================================
# ML ANALYTICS (optionnel – pour prédictions)
# ============================================================================
ML_MODELS_PATH=/home/user/olt_supervision/data/ml_models
ML_TRAINING_DATA_PATH=/home/user/olt_supervision/data/ml_data
ML_DEFAULT_HORIZON=30
ML_FORECAST_CONFIDENCE=95
ML_ANOMALY_CONTAMINATION=0.1
ML_AUTO_RETRAIN=True
ML_RETRAIN_FREQUENCY_HOURS=24

# ============================================================================
# ALERTES & SEUILS
# ============================================================================
# Seuils par défaut pour la détection d'anomalies
ALERT_CPU_THRESHOLD=85.0
ALERT_TEMPERATURE_THRESHOLD=75.0
ALERT_PACKET_LOSS_THRESHOLD=1.0
ALERT_RX_POWER_THRESHOLD=-25.0

MAX_NOTIFICATIONS_PER_HOUR=100
MAX_NOTIFICATIONS_PER_DAY=1000
ALERT_COOLDOWN_MINUTES=60

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=/home/user/olt_supervision/logs/olt_supervision.log

# ============================================================================
# PERFORMANCE
# ============================================================================
CACHE_TTL=3600
DATABASE_CONNECTION_POOL_SIZE=20
DATABASE_CONNECTION_MAX_AGE=600

# ============================================================================
# API RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_WEBSOCKETS=True
ENABLE_CELERY_BEAT=True
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_SMS_NOTIFICATIONS=False
ENABLE_SLACK_NOTIFICATIONS=False
ENABLE_TEAMS_NOTIFICATIONS=False
ENABLE_ML_ANALYTICS=True

# ============================================================================
# WEBHOOKS
# ============================================================================
WEBHOOK_RETRY_COUNT=3
WEBHOOK_TIMEOUT_SECONDS=10